{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./js",
    "rootDir": "./js",
    "declaration": false,
    "noEmit": false
  },
  "include": ["js/**/*"],
  "exclude": ["node_modules"]
}
